<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Liquid Glass Launcher</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome para Iconos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(255, 255, 255, 0.2);
            --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
            --liquid-blur: blur(12px);
            --accent-color: #007aff; /* Estilo iOS */
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow: hidden;
            /* Fondo de pantalla vibrante estilo ColorOS/RealmeUI */
            background: linear-gradient(45deg, #ff9a9e 0%, #fecfef 99%, #fecfef 100%);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            color: white;
            user-select: none;
            -webkit-user-select: none;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Efecto Liquid Glass Global */
        .liquid-glass {
            background: var(--glass-bg);
            backdrop-filter: var(--liquid-blur);
            -webkit-backdrop-filter: var(--liquid-blur);
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
            border-radius: 28px; /* Redondeo al estilo HyperOS/iOS */
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        .liquid-glass:active {
            transform: scale(0.95);
            background: rgba(255, 255, 255, 0.2);
        }

        /* Contenedor Principal */
        #phone-container {
            width: 100vw;
            height: 100vh;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Isla Dinámica (Dynamic Island) */
        #dynamic-island {
            position: absolute;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            height: 30px;
            background: black;
            border-radius: 20px;
            z-index: 100;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 10px;
            color: white;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }

        #dynamic-island.expanded {
            width: 300px;
            height: 80px;
            border-radius: 30px;
            padding: 15px;
        }

        #dynamic-island .content {
            opacity: 0;
            transition: opacity 0.3s;
            display: none;
            width: 100%;
        }

        #dynamic-island.expanded .content {
            opacity: 1;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Pantalla de Bloqueo */
        #lock-screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 50;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding-top: 15vh;
            transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.5s;
            background: rgba(0,0,0,0.1);
            backdrop-filter: blur(5px);
        }

        #lock-screen.unlocked {
            transform: translateY(-100%);
            opacity: 0;
            pointer-events: none;
        }

        /* Reloj Estirable */
        .stretch-clock {
            font-size: 6rem;
            font-weight: 700;
            text-align: center;
            line-height: 1;
            letter-spacing: -2px;
            text-shadow: 0 2px 10px rgba(0,0,0,0.3);
            transition: all 0.3s ease;
            cursor: ns-resize; /* Indicador de estiramiento */
            transform-origin: center;
        }

        .stretch-clock .date {
            font-size: 1.2rem;
            font-weight: 500;
            letter-spacing: normal;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        /* Área de Desbloqueo */
        .unlock-area {
            position: absolute;
            bottom: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-15px); }
            60% { transform: translateY(-7px); }
        }

        /* Pantalla de Inicio (Home Screen) */
        #home-screen {
            flex: 1;
            padding: 60px 20px 100px 20px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-auto-rows: min-content;
            gap: 20px 15px;
            opacity: 0;
            transform: scale(0.95);
            transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
            z-index: 10;
        }

        #home-screen.active {
            opacity: 1;
            transform: scale(1);
        }

        /* Iconos de Apps */
        .app-icon-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            cursor: pointer;
        }

        .app-icon {
            width: 60px;
            height: 60px;
            border-radius: 22%; /* Estilo iOS/HyperOS */
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.8rem;
            color: white;
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            transition: transform 0.2s;
        }

        .app-icon-wrapper:active .app-icon {
            transform: scale(0.85);
        }

        .app-label {
            font-size: 0.75rem;
            text-shadow: 0 1px 3px rgba(0,0,0,0.5);
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 70px;
            text-align: center;
        }

        /* Widgets (Estilo ColorOS/Realme UI) */
        .widget {
            grid-column: span 2;
            height: 140px;
            border-radius: 28px;
            padding: 15px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .widget-large {
            grid-column: span 4;
            height: 160px;
        }

        /* Dock (Barra Inferior) */
        #dock {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: 90%;
            height: 80px;
            border-radius: 35px;
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding: 0 10px;
            z-index: 20;
        }

        #dock .app-icon {
            box-shadow: none;
        }

        /* Centro de Control */
        #control-center {
            position: absolute;
            top: 0;
            right: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            z-index: 200;
            transform: translateY(-100%);
            transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
            padding: 60px 20px 20px 20px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            align-content: start;
        }

        #control-center.active {
            transform: translateY(0);
        }

        .cc-module {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            font-size: 1.5rem;
            transition: all 0.2s;
            cursor: pointer;
        }
        
        .cc-module.active-btn {
            background: var(--accent-color);
        }

        .cc-module-2x2 {
            grid-column: span 2;
            grid-row: span 2;
            flex-direction: column;
            gap: 10px;
        }
        
        .cc-module-2x1 {
             grid-column: span 2;
        }

        .cc-slider-container {
             grid-column: span 4;
             background: rgba(255, 255, 255, 0.15);
             border-radius: 20px;
             padding: 15px;
             display: flex;
             align-items: center;
             gap: 15px;
        }
        
        /* Sliders personalizados */
        input[type=range] {
            -webkit-appearance: none;
            width: 100%;
            background: transparent;
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 24px;
            width: 24px;
            border-radius: 50%;
            background: white;
            cursor: pointer;
            margin-top: -10px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        input[type=range]::-webkit-slider-runnable-track {
            width: 100%;
            height: 6px;
            cursor: pointer;
            background: rgba(255,255,255,0.3);
            border-radius: 3px;
        }

        /* Gestures Area (Top right for Control Center) */
        #cc-trigger-area {
            position: absolute;
            top: 0;
            right: 0;
            width: 50%;
            height: 30px;
            z-index: 300;
        }
        
        /* Animaciones de entrada de apps */
        .app-opening {
            animation: expandApp 0.4s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
            position: absolute !important;
            z-index: 999;
        }
        
        @keyframes expandApp {
            0% { transform: scale(1); opacity: 1; border-radius: 22%; }
            100% { transform: scale(10); opacity: 0; border-radius: 0; }
        }

    </style>
</head>
